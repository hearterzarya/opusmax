# Environment Variables for OpusX Gateway
# Copy this to .env.local and fill in the values

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DATABASE?sslmode=require

# Redis (Upstash)
REDIS_URL=redis://default:xxxx@xxx.upstash.io:6379

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Upstream Base URL (with or without trailing /v1 — both work; do NOT point at your own gateway)
UPSTREAM_ANTHROPIC_BASE_URL=https://api.anthropic.com

# Admin Authentication
ADMIN_EMAIL=admin@opusx.gateway
ADMIN_PASSWORD=YourSecurePassword123!
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars-long
# Optional: set true to allow env-based admin recovery in production
ALLOW_ENV_ADMIN_BOOTSTRAP=false

# Optional: set to 1 to return 502 when Anthropic /v1/models fails (default: built-in model list for UIs)
# GATEWAY_DISABLE_MODELS_FALLBACK=1

# Merge built-in model aliases into successful upstream /v1/models (default on). Set 0 to only show Anthropic list.
# GATEWAY_MERGE_MODEL_FALLBACK=0

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- API consumers (Claude Code, Cursor, SDK) — set on the client, not on this server ---
# ANTHROPIC_BASE_URL=https://YOUR_DEPLOYMENT_ORIGIN/api
# ANTHROPIC_API_KEY=sk-ant-ox-...   # key issued from this gateway's admin UI