// Prisma Schema for OpusX Gateway

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApiKeyStatus {
  ACTIVE
  PAUSED
  EXPIRED
  REVOKED
}

enum PlanTier {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum ServiceStatus {
  HEALTHY
  DEGRADED
  DOWN
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  auditLogs AuditLog[]

  @@map("admin_users")
}

model Plan {
  id                 String    @id @default(cuid())
  name               String    @unique
  tier               PlanTier  @default(FREE)
  tokenLimitMonthly  BigInt?
  rpmLimit           Int       @default(60)
  hourlyTokenBudget  BigInt?
  priceMonthly       Decimal   @db.Decimal(10, 2) @default(0)
  description        String?
  features           String[]
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  apiKeys ApiKey[]

  @@map("plans")
}

model ApiKey {
  id                   String        @id @default(cuid())
  keyHash              String        @unique
  keyPrefix            String
  keyFullLast4         String
  name                 String
  planId               String?
  status               ApiKeyStatus  @default(ACTIVE)
  rpmLimit             Int           @default(60)
  hourlyTokenBudget    BigInt?
  monthlyTokenBudget   BigInt?
  quotaWindowStartAt   DateTime?
  expiresAt            DateTime?
  lastUsedAt           DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  plan      Plan?       @relation(fields: [planId], references: [id])
  usageLogs UsageLog[]

  @@index([keyHash])
  @@index([status])
  @@map("api_keys")
}

model UsageLog {
  id            String   @id @default(cuid())
  apiKeyId      String
  model         String
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  totalTokens   Int      @default(0)
  latencyMs     Int      @default(0)
  statusCode    Int
  errorType     String?
  errorMessage  String?
  timestamp     DateTime @default(now())

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId])
  @@index([timestamp])
  @@index([model])
  @@map("usage_logs")
}

model SystemHealthLog {
  id        String        @id @default(cuid())
  service   String
  status    ServiceStatus @default(HEALTHY)
  latencyMs Int?
  message   String?
  timestamp DateTime      @default(now())

  @@index([service])
  @@index([timestamp])
  @@map("system_health_logs")
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  details   Json?
  ipAddress String?
  timestamp DateTime @default(now())

  admin AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([timestamp])
  @@map("audit_logs")
}


model ApiLatencyMetric {
  id        String @id @default(cuid())
  requestId String @unique

  sourceType     String   // REAL_TRAFFIC, SYNTHETIC_VENDOR, SYNTHETIC_OPUSX, REGION_PROBE
  probeRegion    String?
  requestedModel String?
  returnedModel  String?

  authMs       Float?
  quotaMs      Float?
  routingMs    Float?
  preVendorMs  Float?

  vendorHeadersMs    Float?
  vendorFirstByteMs  Float?
  vendorFirstTokenMs Float?
  vendorTotalMs      Float?

  opusxFirstTokenMs Float?
  opusxTotalMs      Float?

  firstTokenOverheadMs          Float?
  postVendorFirstTokenOverheadMs Float?
  streamCompletionOverheadMs    Float?

  statusCode   Int?
  success      Boolean
  errorType    String?
  errorMessage String?

  createdAt DateTime @default(now())

  @@index([sourceType, createdAt])
  @@index([success, createdAt])
  @@index([requestedModel, createdAt])
  @@index([createdAt])
  @@map("api_latency_metrics")
}


model Provider {
  id            String   @id @default(cuid())
  name          String   @unique
  displayName   String
  baseUrl       String
  authMethod    String   // x-api-key, bearer, oauth, custom-header
  authHeaderName String? // custom header name if authMethod=custom-header
  authValue     String   // encrypted/stored API key or token value
  isActive      Boolean  @default(true)
  isDefault     Boolean  @default(false)
  anthropicVersion String? @default("2023-06-01")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("providers")
}
