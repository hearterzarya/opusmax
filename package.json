{
  "name": "opusx-gateway",
  "version": "1.0.0",
  "description": "OpusX Gateway - AI API Gateway SaaS",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node -e \"require('node:fs').rmSync('.next', { recursive: true, force: true })\"",
    "build": "next build",
    "prestart": "node -e \"const fs=require('fs');if(!fs.existsSync('.next/BUILD_ID')){console.error('\\nMissing production build. Run: npm run build\\n');process.exit(1)}\"",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "next typegen && tsc --noEmit --incremental false",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:clear-key-expiry": "prisma db execute --file prisma/sql/clear-key-expiry.sql --schema prisma/schema.prisma",
    "cli:dev": "pnpm --filter opusmaxx dev",
    "cli:build": "pnpm --filter opusmaxx build",
    "cli:link": "pnpm --filter opusmaxx link --global",
    "cli:publish": "pnpm --filter opusmaxx publish --access public",
    "cf:build": "WRANGLER_BUILD_CONDITIONS= WRANGLER_BUILD_PLATFORM=node opennextjs-cloudflare build",
    "cf:preview": "WRANGLER_BUILD_CONDITIONS= WRANGLER_BUILD_PLATFORM=node opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:deploy": "WRANGLER_BUILD_CONDITIONS= WRANGLER_BUILD_PLATFORM=node opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:upload": "WRANGLER_BUILD_CONDITIONS= WRANGLER_BUILD_PLATFORM=node opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@hookform/resolvers": "^4.0.0",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^6.6.0",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.7",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ioredis": "^5.6.1",
    "jose": "^6.0.10",
    "lucide-react": "^0.475.0",
    "next": "^15.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.2",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7",
    "uncrypto": "^0.1.3",
    "undici": "^6.26.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.6",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.21.0",
    "eslint-config-next": "^15.2.4",
    "postcss": "^8.5.3",
    "prisma": "^6.6.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "wrangler": "^4.98.0",
    "ws": "^8.21.0"
  }
}